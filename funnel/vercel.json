{
  "redirects": [
    {
      "source": "/",
      "destination": "/funnel-v2/",
      "permanent": false
    },
    {
      "source": "/funnel-v1",
      "destination": "/funnel-v1/",
      "permanent": false
    },
    {
      "source": "/funnel-v2",
      "destination": "/funnel-v2/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/funnel-v1/",
      "destination": "/funnels/v1/index.html"
    },
    {
      "source": "/funnel-v2/",
      "destination": "/funnels/v2/index.html"
    },
    {
      "source": "/funnel-v1/:path+",
      "destination": "/funnels/v1/:path+"
    },
    {
      "source": "/funnel-v2/:path+",
      "destination": "/funnels/v2/:path+"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ]
    }
  ]
}
