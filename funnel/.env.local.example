# Funnel Serverless Functions — Environment Variables
# Copy this file to .env.local and fill in your values.
# In production, set all vars in the Vercel project dashboard (Settings → Environment Variables).

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Stripe ────────────────────────────────────────────────────────────────────
# Publishable key: lives in funnel/app.js → CONFIG.stripePk (safe for frontend)
# Secret key: server-side only — never put in frontend code
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret:
#   Local:      stripe listen --forward-to localhost:8080/api/webhook  → prints whsec_...
#   Production: Stripe Dashboard → Developers → Webhooks → Add endpoint → copy whsec_...
#   Events to subscribe: invoice.payment_succeeded
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Stripe Price IDs (test mode) ──────────────────────────────────────────────
# Create in Stripe Dashboard → Products (Test mode)
#
# Product A "Compass Monthly" — 3 prices:
STRIPE_PRICE_INTRO_7DAY=price_...        # €10.50  recurring weekly  (intro for 7-day plan)
STRIPE_PRICE_INTRO_1MONTH=price_...      # €19.99  recurring monthly (intro for 1-month plan)
STRIPE_PRICE_REGULAR_MONTHLY=price_...   # €49.99  recurring monthly (ongoing after intro)
#
# Product B "Compass Quarterly" — 2 prices:
STRIPE_PRICE_INTRO_3MONTH=price_...      # €34.99  recurring every 3 months (intro)
STRIPE_PRICE_REGULAR_QUARTERLY=price_... # €99.99  recurring every 3 months (ongoing)
