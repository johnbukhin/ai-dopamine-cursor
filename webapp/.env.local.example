# Compass Webapp — Environment Variables
# Copy this file to .env.local and fill in your values.
# In production, set these in the Vercel project dashboard (Settings → Environment Variables).

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Anthropic Claude ──────────────────────────────────────────────────────────
# Found in: Anthropic Console → API Keys (console.anthropic.com)
# IMPORTANT: server-side only — no VITE_ prefix. Used by webapp/api/coach.js
# and webapp/api/daily-insight.js. Set in Vercel project env vars for prod.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Optional App Links ─────────────────────────────────────────────────────────
# Funnel base URL — used by Login.tsx "Start my journey" link and
# Settings → Terms tab links to /legal/*.html. Must be the funnel ORIGIN
# (no path suffix); /funnel/ was removed during the funnels/ flatten refactor.
VITE_FUNNEL_URL=https://ai-dopamine-addict.vercel.app

# ── Vercel Setup (separate project from funnel) ───────────────────────────────
# 1. In Vercel dashboard → "Add New Project" → import johnbukhin/ai-dopamine-cursor
# 2. Root Directory: webapp
# 3. Framework Preset: Vite (auto-detected)
# 4. Add the three env vars above under "Environment Variables"
# 5. Deploy → copy the Vercel URL
# 6. Set CONFIG.webappUrl in funnel/app.js to the deployed URL
