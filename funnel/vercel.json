{
  "redirects": [
    {
      "source": "/",
      "destination": "/funnel-v2/",
      "permanent": false
    },
    {
      "source": "/funnel-v1",
      "destination": "/funnel-v1/",
      "permanent": false
    },
    {
      "source": "/funnel-v2",
      "destination": "/funnel-v2/",
      "permanent": false
    },
    {
      "source": "/funnel-v2/terms-of-use.html",
      "destination": "/legal/terms-of-use.html",
      "permanent": true
    },
    {
      "source": "/funnel-v2/privacy-policy.html",
      "destination": "/legal/privacy-policy.html",
      "permanent": true
    },
    {
      "source": "/funnel-v2/subscription-policy.html",
      "destination": "/legal/subscription-policy.html",
      "permanent": true
    },
    {
      "source": "/funnel-v2/cookie-policy.html",
      "destination": "/legal/cookie-policy.html",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/legal/:path+",
      "destination": "/legal/:path+"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ]
    }
  ]
}
