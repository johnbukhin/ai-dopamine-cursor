# Compass Webapp — Environment Variables
# Copy this file to .env.local and fill in your values.
# In production, set these in the Vercel project dashboard (Settings → Environment Variables).

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Google Gemini AI ──────────────────────────────────────────────────────────
# Found in: Google AI Studio → API Keys (aistudio.google.com)
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# ── Vercel Setup (separate project from funnel) ───────────────────────────────
# 1. In Vercel dashboard → "Add New Project" → import johnbukhin/ai-dopamine-cursor
# 2. Root Directory: webapp
# 3. Framework Preset: Vite (auto-detected)
# 4. Add the three env vars above under "Environment Variables"
# 5. Deploy → copy the Vercel URL
# 6. Set CONFIG.webappUrl in funnel/app.js to the deployed URL
